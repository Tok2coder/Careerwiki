        { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "9/28~10/2" }] }] },
        { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "10/31 (토)" }] }] },
