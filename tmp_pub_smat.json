            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "서비스 마케팅/세일즈" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "서비스 세일즈·상담, CRM, VOC 분석, 컴플레인 처리, 유통관리, 코칭·멘토링" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "50문항 / 70분" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "★★★★☆ (가장 어려움)" }] }] }
          ]
        },
        {
