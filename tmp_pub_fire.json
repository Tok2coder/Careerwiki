            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "과목당 40점 이상 + 평균 60점 이상" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "과목당 40점 이상 + 평균 60점 이상" }] }] }
          ]
        },
        {
          "type": "tableRow",
