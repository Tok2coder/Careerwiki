  "overview": {
    "title": "자격증 개요",
    "description": "전기공사기사는 한국산업인력공단에서 시행하는 국가기술자격으로, 1974년 신설되어 현재까지 운영되고 있다. 전기 시설의 설치·시공·감독 업무를 수행하기 위한 기사급 자격증으로, 전기공사업법에 의한 전기공사업 등록 시 필수 기술인력으로 인정된다.",
    "governing_body": "한국산업인력공단 (Q-Net)",
    "related_ministry": "산업통상자원부",
    "established_year": 1974,
    "customer_support": "1644-8000 (09:00~18:00, 유료)",
    "eligibility": {
      "summary": "기사 등급 공통 응시자격 적용. 학력·경력·자격 중 하나 이상 충족 필요.",
      "by_education": [
        "4년제 대학 관련학과 졸업자 또는 졸업예정자",
        "3년제 전문대학 관련학과 졸업 후 동일(유사)분야 1년 이상 실무경력자",
        "2년제 전문대학 관련학과 졸업 후 동일(유사)분야 2년 이상 실무경력자"
      ],
      "by_career": [
        "동일(유사)분야에서 4년 이상 실무 종사자",
        "산업기사 취득 후 동일(유사)분야 1년 이상 실무경력자",
        "기능사 취득 후 동일(유사)분야 3년 이상 실무경력자"
      ],
      "by_qualification": [
        "동일(유사)분야 다른 종목 기사 자격 취득자",
        "산업기사 수준 기술훈련과정 이수 후 2년 이상 실무경력자"
      ],
      "related_departments": "전기전자공학과, 통신공학과, 기계공학과, 건축공학과, 토목공학과, 컴퓨터공학과, 재료공학과 등 공대 관련학과 폭넓게 인정",
      "tip": "응시자격 판단이 복잡한 경우 Q-Net의 응시자격 자가진단 시스템 활용 가능"
    },
    "sources": [
      "https://namu.wiki/w/%EC%A0%84%EA%B8%B0%EA%B3%B5%EC%82%AC%EA%B8%B0%EC%82%AC",
      "http://www.q-net.or.kr/crf005.do?id=crf00503&jmCd=1160",
      "https://www.q-net.or.kr/crf006.do?id=crf00603&tabIdx=2&gradeType=30",
      "http://daehan-e.co.kr/contents/02_license/sub03.html"
    ]
  },

  "exam_structure": {
