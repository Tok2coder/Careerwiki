    "written_exam_strategy": {
      "for_electrical_engineer_holders": [
        "제1과목(전기응용 및 공사재료)에만 집중",
        "공사재료, 조명공학, 전기철도 부분 중점 학습",
        "기출문제 10개년 이상 풀이로 출제 패턴 파악"
      ],
      "for_first_timers": [
        "과목별 추천 학습 순서: 전기기기 → 전력공학 → 회로이론 → 전기설비 → 전기응용",
        "인터넷 강의 1회독 후 기출문제 중심 반복 학습",
        "과목별 난이도: 전기기기 > 전력공학 > 회로이론 > 전기설비 > 전기응용",
        "동영상 2배속 1회 시청 → 문제풀이 중심 → 이해 안 되는 부분만 재시청"
      ],
      "for_non_major": [
        "순수 독학은 거의 불가능 - 인강 또는 오프라인 학원 필수",
        "기초 이론(회로이론, 전자기학)부터 탄탄히 쌓은 후 과년도 기출문제 풀이",
        "최소 300시간 이상 투자 필요"
      ]
    },
    "practical_exam_strategy": {
      "general": [
        "기출문제 최소 17개년 이상, 4회독 이상 반복 권장",
        "최신 기출 → 과거 기출 역순 학습 → 다시 최신 기출로 마무리",
        "계산문제는 최근 기출이 더 어려운 경향"
      ],
      "estimate_problem_tips": [
        "견적 문제는 전기공사기사 고유 유형 - 별도 학습 필요",
        "물량 산출(전선·케이블·전선관 길이), 인건비(터파기·포설·철거) 계산 연습",
        "함정 주의: 할증률 적용 방식, 3상/1상 구분, 재사용 재료 구분"
