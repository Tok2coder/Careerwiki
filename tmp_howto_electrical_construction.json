        {
          "number": 4,
          "name": "회로이론 및 제어공학",
          "questions": 20,
          "note": "전기기사와 동일 과목"
        },
        {
          "number": 5,
          "name": "전기설비기술기준",
          "questions": 20,
          "note": "전기기사와 동일 과목"
