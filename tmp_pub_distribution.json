            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "마케팅 믹스(4P), 소비자행동, 촉진전략, 가격전략" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "★★☆☆☆" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "상식적 접근 가능" }] }] }
