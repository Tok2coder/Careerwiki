            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "★★☆☆☆" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "테스트 기법, 형상관리, 통합 — 암기 위주" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "기출 패턴 반복, 안정적 고득점" }] }] }
