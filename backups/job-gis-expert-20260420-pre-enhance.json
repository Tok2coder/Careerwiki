  "overviewAptitude": {
    "aptitudeList": [
      "정보나 데이터를 보고 이해하는 작업이 많기 때문에 통계자료의 도표나 그래프를 이해할 수 있는 수리·논리력이 필요합니다.",
      "입체 구조의 보이지 않는 부분도 파악할 수 있는 공간지각력이 필요합니다."
    ],
    "interestList": [
      "논리적이고 합리적인 사고를 하는 사람에게 적합합니다.",
      "직접 느끼고 움직이는 체험을 중시하는 사람에게 적합합니다."
    ],
    "satisfaction": {
      "value": "73.4"
    }
  },
  "trivia": [
    "GPS와 GIS를 접목한 내비게이션·위치 기반 서비스의 이면에는 GIS전문가가 구축한 방대한 공간 데이터베이스가 있으며, 현재 건설·국방·안전·교통·물류·상권·방범 시스템 등 거의 모든 산업 분야에서 GIS 기술이 활용되고 있다.[1]"
  ],
  "overviewSalary": {
    "sal": "워크넷에 따르면 관련 직종인 지적및측량기술자의 평균 연봉(중앙값)은 5,000만 원(2021년 기준)으로 전체 직업 평균보다 높은 수준이며, 공공기관이나 대형 공간정보 기업에서 상대적으로 높은 처우를 받는 경향이 있다.[1]"
  },
  "detailWlb": {
    "wlb": "보통",
    "social": "보통 이상"
  },
  "detailReady": {
    "curriculum": [
      "지리학과 — GIS의 이론적 토대인 지리 정보 분류·공간 분석·원격탐사 등을 학습하며 GIS전문가로서의 기반을 다질 수 있다.",
      "공간정보공학과/지구정보공학과 — 측량, GIS 소프트웨어 개발, 공간 데이터베이스 등 GIS 분야 핵심 기술을 전문적으로 학습한다.",
      "지적학과 — 토지 정보 관리, 지적 측량, 부동산 정보 시스템 등 지적 분야 GIS 실무에 직결되는 교육과정을 이수할 수 있다.",
      "도시공학과/토목공학과 — 도시 계획, 인프라 설계 등에서 GIS를 활용하는 응용 역량을 키울 수 있다.",
      "GIS 소프트웨어 교육 과정 — ArcGIS, QGIS 등 GIS 전문 소프트웨어 활용 능력을 키우는 국비 또는 민간 교육 과정을 통해 취업 역량을 높일 수 있다.[1]"
    ],
    "recruit": [
      "공간정보·측량 전문 기업 채용 — 측량 전문업체, 지도제작 기업, 드론 측량 기업 등에서 GIS 데이터 구축·분석 인력을 수시로 채용한다.",
      "공공기관 채용 — 한국국토정보공사, 한국토지주택공사, 한국수자원공사, 국토교통부 국토지리정보원 등에서 GIS 전문 인력을 채용한다.",
      "민간 IT·건설 기업 채용 — 내비게이션 서비스사, 스마트시티 기업, 건설사 등에서 공간정보 분석가를 수시 채용한다.[1]"
    ],
    "training": [
      "K-디지털 트레이닝 GIS·공간정보 과정 — 고용노동부 지원으로 GIS 소프트웨어 활용, 공간 데이터 분석, 드론 측량 등의 실무 과정을 배울 수 있다.",
      "내일배움카드 측량·공간정보 훈련 — 고용24에서 지원하는 GIS·측량 관련 직업훈련으로, 자격증 취득과 취업 연계를 함께 준비할 수 있다.[1]"
    ],
    "researchList": [
      "코딩 연습 - 각종 코딩 사이트나 코딩 프로그램을 통한 코딩 연습으로 모바일 웹, 모바일 애플리케이션 개발에 필요한 프로그래밍에 대한 기초 지식과 원리를 이해할 수 있습니다.",
      "GIS 프로그래밍 학습 - GIS 프로그래밍을 배우며 GIS의 주요 용어를 익힐 수 있습니다."
    ],
    "certificate": [
      "국가자격증으로는 지적기능사, 지적산업기사, 지적기술사, 지적기사, 지질및지반기술사, 측량및지형공간정보기술사 자격증이 있습니다."
    ]
  },
