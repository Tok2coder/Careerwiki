  "sections": {
    "1_certification_structure": {
      "title": "자격증 종류/등급 구조",
      "overview": "전산세무회계는 한국세무사회가 주관하는 국가공인 민간자격으로, 4개 등급으로 구성된다.",
      "grades": [
        {
          "name": "전산회계 2급",
          "level": "입문",
          "target": "상업고등학교 졸업자 수준",
          "scope": "회계원리 기초",
          "national_equivalent": "기능사급"
        },
        {
          "name": "전산회계 1급",
          "level": "초급",
          "target": "전문대학 재학 수준",
          "scope": "회계원리, 원가회계, 부가가치세법 기초",
          "national_equivalent": "산업기사급"
        },
        {
          "name": "전산세무 2급",
          "level": "중급",
          "target": "전문대학 졸업 수준",
          "scope": "재무회계, 원가회계, 부가가치세, 소득세, 원천징수, 연말정산",
          "national_equivalent": "산업기사급"
        },
        {
          "name": "전산세무 1급",
          "level": "고급",
          "target": "4년제 대학 전공자 수준",
          "scope": "재무회계, 원가회계, 세무회계(부가세·소득세·법인세) 전체",
          "national_equivalent": "기사급"
        }
      ],
      "difficulty_order": "전산세무 1급 > 전산세무 2급 > 전산회계 1급 > 전산회계 2급",
      "key_differences": {
        "전산회계_vs_전산세무": "전산회계는 회계원리·원가회계 중심, 전산세무는 세무회계(부가세·소득세·법인세) 추가",
        "전산세무_2급_vs_1급": "전산세무 2급은 부가세·소득세·원천세·연말정산까지, 1급은 여기에 법인세까지 포함",
        "전산회계_1급_vs_2급": "전산회계 2급은 회계원리만, 1급은 원가회계·부가가치세법 추가"
      }
    },
