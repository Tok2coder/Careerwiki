# Phase 3: Google OAuth 환경 변수
# 이 파일을 복사하여 .dev.vars 파일을 생성하세요.
# 
# 주의: .dev.vars는 절대 Git에 커밋하지 마세요!
# (.gitignore에 이미 포함되어 있습니다)

# Google OAuth Client ID
# Google Cloud Console > APIs & Services > Credentials에서 생성
# 형식: xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google OAuth Client Secret
# Google Cloud Console > APIs & Services > Credentials에서 확인
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Callback URL
# 로컬 환경: http://localhost:3000/auth/google/callback
# 프로덕션: https://careerwiki.org/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# JWT Secret Key (32+ characters recommended)
# 생성 방법: openssl rand -base64 32
# 또는: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_random_secret_key_here_minimum_32_characters

# 공공데이터 API 키 — 공공데이터포털 또는 work24.go.kr 개발자 등록에서 발급
# 형식: UUID 8-4-4-4-12 (예: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# ⚠️ 한 번 발급된 키는 재발급 불가 영역 있음 — 절대 커밋 금지, 비밀번호 매니저 백업 권장
# CAREER_NET_API_KEY=공공데이터포털에서_발급받은_값
# GOYONG24_MAJOR_API_KEY=고용24_학과_API_키
# GOYONG24_JOB_API_KEY=고용24_직업_API_키

# Admin Secret — 편집 API 인증용
# 프로덕션 등록: npx wrangler pages secret put ADMIN_SECRET --project-name careerwiki
# ADMIN_SECRET=임의의_비밀키

# Metrics Secret — /api/admin/metrics/v1 전용, ADMIN_SECRET 과 반드시 분리
# 프로덕션 등록: npx wrangler pages secret put METRICS_SECRET --project-name careerwiki
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 스펙: docs/api-metrics-spec.md
# METRICS_SECRET=your_metrics_secret_here


