      .replace(/\[\[major:([^\]]+)\]\]/g, '<a href="/major/$1" class="text-wiki-primary hover:text-wiki-secondary underline">$1</a>')
      .replace(/\[\[howto:([^\]]+)\]\]/g, '<a href="/howto/$1" class="text-wiki-primary hover:text-wiki-secondary underline">$1</a>')
