    const isAdmin =
      state.viewerRole === 'admin' ||
      state.viewerRole === 'super-admin' ||
      state.viewerRole === 'operator'
    const isOwner = comment.authorId && state.viewer?.id && String(state.viewer.id) === String(comment.authorId)
