        }

        // ?⑥닚 ?섏젙???뚮뒗 source瑜?鍮?臾몄옄?대줈 ?꾩넚
        const sourceToSend = editType === 'simple' ? '' : source;
        
        return fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            field,
            content,
            source: sourceToSend
          })
        });
      });

      const responses = await Promise.all(editPromises);
