const parseNumberFromText = (value) => {
  if (!value) return 0;
  const numeric = String(value).replace(/[^0-9.,-]/g, '').replace(/,/g, '');
  if (!numeric) return 0;
  const parsed = parseFloat(numeric);
  return Number.isFinite(parsed) ? parsed : 0;
};

