    const commentAriaLabel = escapeHtml(commentLabelParts.join(', '))

    const menuId = `comment-menu-${comment.id}`
    // ?듬챸 ?볤??먮쭔 IP ?쒖떆 (愿꾪샇 ?뺤떇)
