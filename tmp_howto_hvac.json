  "sections": {
    "overview": {
      "title": "자격증 개요",
      "content": {
        "description": "공조냉동기계기사는 냉동·공조 설비의 설계, 시공, 감리, 유지보수를 수행하는 국가기술자격증이다. 건축물의 냉난방, 환기, 공기정화 시스템과 산업용 냉동·냉장 설비 전반을 다룬다.",
        "governing_body": "한국산업인력공단 (Q-net)",
        "legal_basis": "국가기술자격법",
        "qualification_requirements": [
          "관련학과 4년제 대학교 졸업(예정)자",
          "3년제 전문대학 졸업자 + 실무경력 1년",
          "2년제 전문대학 졸업자 + 실무경력 2년",
          "산업기사 취득 후 실무경력 1년",
          "기능사 취득 후 실무경력 3년",
          "순수 실무경력 4년 이상 (동일·유사 분야)",
          "학점은행제 106학점 이상 (전공 28학점 포함)"
        ],
        "related_departments": [
          "기계공학과",
          "냉동공조공학과",
          "건축설비공학과",
          "건축설비학과",
          "건축설비자동화과",
          "산업설비과",
          "산업설비자동화과",
          "에너지시스템공학과"
        ],
        "note": "관련 학과명 변경·교육인정 변경이 잦으므로 큐넷 응시자격 자가진단 또는 1644-8000 통해 확인 권장"
      },
      "sources": [
        "https://www.q-net.or.kr/crf005.do?id=crf00503&jmCd=1730",
        "https://namu.wiki/w/%EA%B3%B5%EC%A1%B0%EB%83%89%EB%8F%99%EA%B8%B0%EA%B3%84%EA%B8%B0%EC%82%AC",
        "https://safeegac.moa-ba.com/htmlpage.php?no=271"
      ]
    },
    "exam_structure": {
      "title": "시험 구조",
      "content": {
        "note": "2022년 출제기준 개편으로 기존 5과목 100문제에서 4과목 80문제로 변경. 2025년부터 시험시간 축소 적용.",
        "written_exam": {
          "name": "필기시험",
          "format": "객관식 4지택일",
          "subjects": [
            {
              "name": "에너지관리",
              "questions": 20,
              "description": "기계열역학, 에너지 효율, 열전달 기초"
            },
            {
              "name": "공조냉동설계",
              "questions": 20,
              "description": "냉동공학(P-H선도, 냉동사이클), 공기조화(습공기선도, 덕트설계, 냉난방 부하계산)"
            },
            {
              "name": "시운전 및 안전관리",
              "questions": 20,
              "description": "냉동장치 운전, 고압가스 안전관리, 설비 안전"
            },
            {
              "name": "유지보수 및 공사관리",
              "questions": 20,
              "description": "배관공학, 전기제어, 설비 유지보수, 공사관리"
            }
          ],
          "total_questions": 80,
          "time_limit": "80분 (2025년~, 문제당 1분)",
          "passing_criteria": "과목당 40점 이상, 전과목 평균 60점 이상"
        },
        "practical_exam": {
          "name": "실기시험",
          "format": "필답형 (서술형·계산형)",
          "questions": "약 12문제",
          "time_limit": "90분 (1시간 30분)",
          "total_score": 100,
          "passing_criteria": "60점 이상",
          "key_topics": [
            "P-H선도를 이용한 냉동사이클 계산",
            "습공기선도를 이용한 공조 시스템 설계",
            "냉난방 부하 계산",
            "덕트·배관 설계 및 용량 산정",
            "냉동장치 구성 및 운전 조건 분석"
          ],
          "note": "기사급은 100% 필답형 (산업기사·기능사는 동관작업 포함 복합형). 계산문제가 주를 이루며 한 문제가 2~3페이지에 걸친 서술형이 대부분. 도면의 방위표 함정, 조건 변형 등 출제 트랩에 주의 필요."
        }
      },
