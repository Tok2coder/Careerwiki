    "study_method": {
      "title": "공부법 및 학습 전략",
      "content": {
        "total_study_period": {
          "written": "4~8주 (비전공자 8주, 전공자 4주 권장)",
          "practical": "4~8주 (필기 합격 후 바로 시작 권장)",
          "total": "약 2~4개월"
        },
        "subject_strategy": {
          "에너지관리": "기계열역학이 모든 과목의 기초. 열·일·에너지 개념, 상태량 변화, 카르노·냉동 사이클 원리를 먼저 확실히 이해해야 이후 과목이 수월함.",
          "공조냉동설계": "핵심 과목. P-H선도(몰리에르 선도) 계산과 습공기선도 활용이 필기·실기 모두 핵심. 냉동사이클 계산, 냉난방 부하계산, 덕트 설계 집중 학습.",
          "시운전_및_안전관리": "암기 비중이 높은 과목. 고압가스 안전관리법 관련 규정, 냉매별 특성, 안전장치 종류와 작동원리 위주로 정리.",
          "유지보수_및_공사관리": "배관·전기제어 기초와 공사관리. 앞선 과목 학습 후 암기 위주로 접근하는 것이 효율적."
        },
        "written_exam_tips": [
          "기출문제 6~10개년 4회독이 정석 (1회독: 풀기, 2회독: 오답노트, 3~4회독: 약점 집중)",
          "이론을 빠르게 훑은 후 기출문제 풀면서 빈출 포인트 암기가 가장 효율적",
          "과목 순서: 에너지관리(열역학) → 공조냉동설계 → 시운전/안전관리 → 유지보수/공사관리",
          "시험시간 80분으로 단축되었으므로 시간 배분 연습 필수"
        ],
        "practical_exam_tips": [
          "기출문제 10~20개년 3~5회독 필수",
          "단순 암기가 아닌 개념·원리 이해 기반 학습 (함정 문제 대비)",
          "P-H선도, 습공기선도 계산을 완벽하게 숙달",
          "도면 방위표 함정, 조건 변형 트랩에 특히 주의",
          "기출 복원 정확도가 낮으므로 공식 유도 능력과 응용력 배양 필요",
          "계산기 사용법 숙달 (공학용 계산기 허용)"
        ],
