            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "핵심 압축, 빠른 회독 중심" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "재시생, 단기 합격 목표" }] }] },
