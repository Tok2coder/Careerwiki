            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "에듀윌" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "체계적 커리큘럼, 합격 환급제" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "초시생, 관리형 학습 선호" }] }] },
