            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "120분" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "20문항 (문항당 5점)" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "60점 이상" }] }] }
