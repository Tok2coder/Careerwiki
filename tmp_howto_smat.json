{
  "cert_name": "SMAT (서비스경영자격)",
  "english_name": "Service Management Ability Test",
  "research_date": "2026-03-26",
  "sections": {
    "overview": {
      "title": "자격증 개요",
      "content": {
        "definition": "SMAT(Service Management Ability Test, 서비스경영자격)는 서비스 산업 분야의 전문 인력을 체계적으로 양성하기 위한 국가직무능력표준(NCS) 기반의 실무형 국가공인 자격시험이다.",
        "governing_body": "한국생산성본부(KPC, Korea Productivity Center)",
        "official_site": "https://license.kpc.or.kr",
        "certification_type": "국가공인 민간자격",
        "national_certification_since": "2015년부터 국가공인 자격시험으로 시행",
        "purpose": "서비스 산업의 핵심 성공 요인(CBK: Common Body of Knowledge)을 추출하여 업종/직무별 경영역량을 객관적이고 신뢰성 있게 평가",
        "grade_structure": {
          "grade_1": {
            "title": "1급 (컨설턴트)",
            "requirement": "모듈 A + B + C 3개 모두 취득",
            "level": "프로페셔널/전문가",
            "credit_recognition": "학점은행제 10학점 인정"
          },
          "grade_2": {
            "title": "2급 (관리자)",
            "requirement": "모듈 A+B 또는 A+C 2개 취득",
            "level": "직무별 특성화 인재",
            "credit_recognition": "학점은행제 6학점 인정"
          },
          "grade_3": {
            "title": "3급 (실무자)",
            "requirement": "모듈 A 1개 취득",
            "level": "서비스 산업 신입사원 수준",
            "credit_recognition": "해당 없음"
          }
        },
        "note": "B 또는 C모듈을 먼저 취득해도 A모듈을 취득해야 자격이 부여되므로 A모듈 우선 취득 권장",
        "applicable_industries": [
          "의료/보건",
          "관광/항공",
          "금융/은행",
          "유통/물류",
          "공공/행정",
          "미용/뷰티",
          "호텔/면세점",
          "교육/훈련"
        ]
      },
      "sources": [
        "https://license.kpc.or.kr/nasec/qlfint/qlfint/selectMatmngmtty.do",
        "https://www.pqi.or.kr/inf/qul/infQulBasDetail.do?qulId=7385",
        "https://www.q-net.or.kr/crf005.do?id=crf00503&jmCd=9980"
      ]
    },
    "exam_structure": {
      "title": "시험 구조",
      "content": {
        "exam_format": "CBT(Computer Based Test) 방식",
        "modules": {
          "module_a": {
            "name": "비즈니스 커뮤니케이션 (Business Communication)",
            "subjects": [
              "비즈니스 매너와 에티켓",
              "이미지 메이킹",
              "고객 심리의 이해",
              "고객 커뮤니케이션",
              "회의 기획 및 의전 실무"
            ],
            "questions": 50,
            "duration_minutes": 70,
            "passing_score": "100점 만점 중 70점 이상",
            "difficulty": "가장 쉬움 (입문 수준)"
          },
          "module_b": {
            "name": "서비스 마케팅/세일즈 (Service Marketing & Sales)",
            "subjects": [
              "서비스 세일즈 및 고객 상담",
              "고객 관리(CRM)",
              "VOC 분석 및 관리",
              "컴플레인 처리",
              "서비스 유통 관리",
              "코칭/교육훈련 및 멘토링 동기부여"
            ],
            "questions": 50,
            "duration_minutes": 70,
            "passing_score": "100점 만점 중 70점 이상",
            "difficulty": "가장 어려움 (탈락률 높음)"
          },
          "module_c": {
            "name": "서비스 운영전략 (Service Operation Strategy)",
            "subjects": [
              "서비스 산업 개론",
              "서비스 프로세스 설계 및 품질관리",
              "서비스 공급 및 수요관리",
              "서비스 인적자원관리(HRM)",
              "고객만족경영(CSM) 전략"
            ],
            "questions": 50,
            "duration_minutes": 70,
            "passing_score": "100점 만점 중 70점 이상",
            "difficulty": "중간"
          }
        },
        "exam_method": "문제은행 방식 (기출 동일/유사 문제 출제)",
        "simultaneous_exam": "같은 날 최대 3개 모듈 동시 응시 가능"
      },
      "sources": [
        "https://license.kpc.or.kr/nasec/qlfint/qlfint/selectMatmngmtty.do",
        "https://www.lecturernews.com/news/articleView.html?idxno=120208",
        "https://wasabisenbe.com/smat-%EC%9E%90%EA%B2%A9%EC%A6%9D%EC%9D%98-%EB%AA%A8%EB%93%A0-%EA%B2%83-feat-%EC%93%B8%EB%AA%A8-%EB%82%9C%EC%9D%B4%EB%8F%84-%EC%8B%9C%ED%97%98-%EC%9D%BC%EC%A0%95-%EB%93%B1/"
      ]
    },
