    "career_and_usage": {
      "title": "취업 활용 및 경력 개발",
      "content": {
        "target_industries": [
          "호텔/리조트 (프론트, 컨시어지, 객실관리)",
          "항공사 (캐빈승무원, 지상직)",
          "면세점/백화점 (판매서비스, 고객상담)",
          "금융/은행 (창구서비스, 고객센터)",
          "병원/의료기관 (의료서비스, 원무과)",
          "유통/물류 (고객관리, CS부서)",
          "공공기관/행정 (민원서비스)",
          "미용/뷰티 (고객응대, 서비스관리)",
          "콜센터/CS부서 (상담, 클레임 처리)"
        ],
        "credit_recognition": {
          "grade_1_10_credits": {
            "major_field": "전문학사(경영, 관광경영), 학사(경영학, 관광경영학, 호텔경영학)",
            "recognition": "전공필수 학점"
          },
          "grade_2_6_credits": {
            "major_field": "전문학사(경영, 관광경영)",
            "recognition": "전공필수 학점"
          }
        },
        "hr_utilization": "신규 인재 채용, 기존 직원 육성, 직원 전환배치 등 HR직무에 활용",
        "corporate_benefits": "다수의 기업과 대학에서 구성원의 서비스 역량 강화를 위해 활용. 서비스 관련 직종 지원 시 가산점 또는 우대 요인으로 작용",
