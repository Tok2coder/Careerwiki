        { "type": "tableHeader", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "난이도" }] }] }
      ] },
      { "type": "tableRow", "content": [
        { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "에너지관리" }] }] },
