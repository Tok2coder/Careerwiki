            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "미용이론, 공중보건학, 소독학, 피부학, 공중위생법규" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "샴푸, 커트, 드라이, 퍼머넌트, 염색" }] }] }
