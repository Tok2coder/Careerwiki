        "https://krjobseeker.com/2025-%EC%86%8C%EB%B0%A9%EC%84%A4%EB%B9%84%EC%82%B0%EC%97%85%EA%B8%B0%EC%82%AC-%EC%9D%91%EC%8B%9C%EC%9E%90%EA%B2%A9-%EB%82%9C%EC%9D%B4%EB%8F%84-%EC%8B%9C%ED%97%98%EC%9D%BC%EC%A0%95-%EC%8B%A4%EA%B8%B0/"
