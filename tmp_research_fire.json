    "5_passing_tips": {
      "title": "합격자 후기에서 자주 나오는 팁",
      "data": {
        "study_order": {
          "electrical": "소방원론 → 소방전기일반 → 소방전기시설의 구조 및 원리 → 소방관계법규",
          "mechanical": "소방원론 → 소방유체역학 → 소방기계시설의 구조 및 원리 → 소방관계법규",
          "rationale": "소방원론이 기초가 되고, 킬러과목을 중간에 배치, 법규는 암기 위주이므로 마지막에 몰아치기"
        },
        "key_tips": [
          "기출문제 반복이 핵심 — 과년도 기출 최소 10개년 3회독 이상",
          "킬러과목(전기일반/유체역학)은 과락만 면하는 전략도 유효 (40점 목표)",
          "법규는 다회독 외에 왕도 없음. 시험 직전 집중 암기",
          "하루에 몰아서 공부하지 말고 매일 꾸준히 — 암기 과목 특성상 분산 학습이 효과적",
          "실기는 필기와 별개로 준비 — 서술형이라 '쓰는 연습' 필수",
          "전기 따고 기계 따는 순서가 일반적 (공통과목 시너지)",
          "인강은 킬러과목만이라도 반드시 수강 — 비전공자 독학 시 시간 낭비 방지",
          "최근 '말문제(서술형 암기)' 출제 비중 증가 → 단순 계산만 연습하면 안 됨",
          "실기 답안 작성 시 성안당 교재의 답안 형식을 그대로 따라쓰기 연습"
        ]
      },
      "sources": [
        "https://k-issue.com/80",
        "https://k-issue.com/81",
        "https://brunch.co.kr/@terrydosa/263",
        "https://www.machuda.kr/blog/article/100",
        "https://www.machuda.kr/blog/article/101",
        "https://knight.eduwill.net/board/qustnView?qustnIdx=51164"
      ]
    },
    "6_vs_industrial_technician": {
      "title": "소방설비기사 vs 소방설비산업기사 차이점",
      "data": {
        "qualification_requirements": {
          "기사": "4년제 대학교 관련학과 졸업(예정)자, 또는 산업기사 + 실무경력 1년, 또는 실무경력 4년 등",
          "산업기사": "관련학과 전문대졸, 또는 4년제 관련학과 1/2 이상 수료, 또는 실무경력 2년 등"
        },
        "difficulty_comparison": {
          "기사": "난이도 높음. 이론 깊이와 범위가 넓음",
          "산업기사": "기사의 하위 호환. 상대적으로 쉬움"
        },
        "career_benefits": {
          "기사": {
            "소방안전관리자": "1급 소방안전관리자 선임 가능",
            "특급_승급": "1급 대상물 5년 경력 시 특급 소방안전관리자 자격",
            "업계_선호": "현장에서 산업기사보다 기사를 확실히 선호"
          },
          "산업기사": {
            "소방안전관리자": "1급 소방안전관리자 자격 발급 가능 (별도 자격/경력 불필요)",
            "특급_승급": "취득 후 7년 경력 시 특급 소방안전관리자 선임 가능"
          }
        },
        "recommendation": "가능하면 기사를 취득하는 것이 취업 및 경력 관리에 유리. 응시자격이 안 되면 산업기사 먼저 취득 후 기사 도전"
      },
      "sources": [
        "https://namu.wiki/w/%EC%86%8C%EB%B0%A9%EC%84%A4%EB%B9%84%EC%82%B0%EC%97%85%EA%B8%B0%EC%82%AC",
