    "7_preparation_period": {
      "title": "준비 기간 (현실적 기간)",
      "data": {
        "written_exam": {
          "with_background": {
            "period": "2~3주",
            "daily_hours": "2~3시간",
            "note": "전기/기계 관련 전공자 또는 유사 자격증 보유자"
          },
          "non_major": {
            "period": "1~2개월",
            "daily_hours": "3~4시간",
            "note": "비전공자는 킬러과목 인강 병행 필수"
          }
        },
        "practical_exam": {
          "period": "1.5~3개월",
          "daily_hours": "3~4시간",
          "note": "서술형 답안 쓰기 연습 필수. 필기와 별도 기간 확보 필요"
        },
        "total_realistic": {
          "minimum": "3개월 (집중 학습, 관련 배경 있는 경우)",
          "average": "4~6개월 (필기+실기 모두 한 번에)",
          "non_major_safe": "6~12개월 (비전공자, 여유 있게)",
          "dual_certification": "12~16개월 (전기+기계 쌍기사)"
        },
        "real_case": "브런치 합격수기: 전기분야 16개월 소요 사례 있음"
      },
      "sources": [
        "https://k-issue.com/80",
