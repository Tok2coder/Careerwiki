    "10_non_major_vs_major": {
      "title": "비전공자 vs 관련 전공자 준비 차이",
      "data": {
        "qualification_path": {
          "related_major": "4년제 관련학과(소방학과, 안전공학과, 전기공학과, 기계공학과 등) 졸업(예정)자 → 바로 응시 가능",
          "non_major": "비관련학과 졸업자 → 실무경력 4년, 또는 산업기사 취득 후 실무경력 1년, 또는 기능사 취득 후 실무경력 3년 필요"
        },
        "study_differences": {
          "major_student": {
            "advantage": "전기일반/유체역학 기초 있어 킬러과목 학습 부담 적음",
            "prep_time": "필기 2~3주, 실기 1.5개월 정도",
            "method": "기출 중심 독학으로 충분"
          },
          "non_major": {
            "challenge": "킬러과목(전기일반/유체역학)에서 기초 개념부터 학습 필요. 독학 시 1년 이상 낭비 가능",
            "prep_time": "필기 1~2개월, 실기 2~3개월",
            "method": "킬러과목은 반드시 인강/유튜브 활용. 완전 독학 비추",
            "recommended_order": "전기분야 먼저 취득 → 기계분야 추가 취득 (공통과목 시너지)"
          }
        },
        "non_major_tips": [
          "산업기사부터 취득하여 응시자격 확보 + 실력 쌓기",
          "킬러과목은 과락 면하기(40점) 전략으로 접근",
          "소방원론/법규에서 고득점하여 평균 60점 달성",
          "유튜브 무료 강의로 킬러과목 기초 쌓은 후 기출 반복",
          "학점은행제로 관련학과 학점 이수하여 응시자격 확보하는 방법도 있음"
        ]
      },
