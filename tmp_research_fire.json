    "3_difficulty_by_subject": {
      "title": "과목별 난이도와 체감 후기",
      "data": {
        "electrical_field": {
          "소방원론": {
            "difficulty": "중",
            "description": "연소, 화재, 소화 등 소방 기본 개념. 다른 과목의 기초가 되므로 가장 먼저 학습 권장"
          },
          "소방전기일반": {
            "difficulty": "상 (킬러과목)",
            "description": "비전공자가 가장 어려워하는 과목. 전기회로, 제어공학 등 전기 기초 필요. 과락 면하고 50~60점 목표 전략 권장. 직류기/동기기/변압기 핵심 파트 집중, 복잡한 계산 문제는 과감히 스킵"
          },
          "소방관계법규": {
            "difficulty": "중상",
            "description": "암기량이 가장 방대한 과목. 다회독 외에 요령 없음. 법규 개정 사항 주의"
          },
          "소방전기시설의 구조 및 원리": {
            "difficulty": "중",
            "description": "실무와 가장 밀접. 소방관계법규와 연관 높아 함께 공부하면 시너지. 설비 작동 원리를 그림과 함께 이해하며 학습"
          }
        },
        "mechanical_field": {
          "소방원론": {
            "difficulty": "중",
            "description": "전기분야와 공통. 기초 과목"
          },
          "소방유체역학": {
            "difficulty": "최상 (킬러과목)",
            "description": "기계분야 최고 난이도. 비전공자 독학 매우 어려움, 인강 필수 권장. 베르누이 방정식 등 유체역학 기초 필요"
          },
          "소방관계법규": {
            "difficulty": "중상",
            "description": "전기분야와 동일"
          },
          "소방기계시설의 구조 및 원리": {
            "difficulty": "중상",
            "description": "스프링클러, 소화전, 위험물 등 다양한 설비 범위. 전기분야보다 학습 범위 넓음"
          }
        },
        "practical_overall": {
          "difficulty": "상",
          "description": "필기보다 체감 난이도 높음. 최근 출제 경향에서 '말문제(서술형 암기)' 비중 증가. 2024~2025 실기 합격률 급락"
        }
      },
      "sources": [
        "https://surius.co.kr/130",
        "https://k-issue.com/80",
        "https://k-issue.com/81",
