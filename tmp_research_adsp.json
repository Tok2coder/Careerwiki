  "6_sqld_comparison_and_parallel_strategy": {
    "comparison": {
      "ADsP": {
        "focus": "통계적 사고 + 분석 프로세스 이해 (이론형)",
        "exam_type": "객관식 50문항, 90분",
        "coding": "R 언어 기초 개념 출제 (코딩 직접 작성 X)",
        "strength": "문과 성향에 유리, 암기 중심",
        "difficulty": "SQLD보다 쉬운 편 (코딩 없음)"
      },
      "SQLD": {
        "focus": "데이터베이스 설계 + SQL 작성 능력 (실무형)",
        "exam_type": "객관식 40문항 + 단답형 10문항, 90분",
        "coding": "SQL 쿼리 작성/해석 필수",
        "strength": "이과 성향에 유리, SQL 실무 능력",
        "difficulty": "ADsP보다 약간 어려움 (코딩 이해 필요)"
      }
    },
    "parallel_strategy": {
      "recommended_order": "SQLD 먼저 → ADsP (SQL 문법과 데이터 구조를 익힌 후 분석으로 확장)",
      "alternative_order": "ADsP 먼저 → SQLD (이론 기반을 잡고 실무로 확장, 문과 성향에 적합)",
      "combined_period": "직장인 기준 주 3회 공부 시 10~12주면 둘 다 합격 가능",
      "synergy": "SQLD(데이터 추출) + ADsP(데이터 해석) = 데이터 리터러시 역량 완성",
      "next_step": "ADsP + SQLD 취득 후 → 빅데이터분석기사 or ADP(데이터분석전문가)로 확장"
    },
