  "researched_at": "2026-03-26",

  "overview": {
    "title": "자격증 개요",
    "description": "미용사(일반)은 고객의 머리카락을 자르고, 파마, 염색, 드라이, 두피케어 등을 수행하는 국가기술자격 기능사 자격증이다. 미용업에 종사하려면 반드시 해당 분야의 미용사 자격증을 취득한 후 면허를 발급받아야 한다.",
    "governing_body": "보건복지부",
    "administering_agency": "한국산업인력공단 (Q-net)",
    "legal_basis": "공중위생관리법",
    "eligibility": "응시 제한 없음 (연령, 학력, 경력 무관). 중고생도 응시 가능하며 최연소 취득자는 초등학교 2학년. 단, 근로자로 일하려면 15세 이상이어야 함.",
    "language_options": "한국어, 중국어, 베트남어 응시 가능",
    "beauty_cert_types": [
      {
        "name": "미용사(일반)",
        "scope": "파마, 커트, 드라이, 두피케어, 염색, 샴푸, 눈썹손질(의료기기/의약품 미사용)",
        "note": "헤어 분야 전반. 가장 응시자가 많은 미용 자격증"
      },
      {
        "name": "미용사(피부)",
        "scope": "얼굴 및 신체 피부의 유지·보호·개선을 위한 기기 및 제품 사용",
        "note": "피부관리사, 에스테틱 분야"
      },
      {
        "name": "미용사(네일)",
        "scope": "손톱·발톱을 건강하고 아름답게 하기 위한 관리법, 기기 및 제품 사용",
        "note": "네일아트, 네일케어 분야"
      },
      {
        "name": "미용사(메이크업)",
        "scope": "이미지분석, 메이크업, 뷰티코디네이션 등 얼굴·신체 표현. 웨딩/시대별/미디어/캐릭터 메이크업 포함",
        "note": "메이크업아티스트, 뷰티코디네이터 분야"
      }
    ],
    "sources": [
      "https://www.q-net.or.kr/crf005.do?id=crf00503&jmCd=7937",
      "https://namu.wiki/w/%EB%AF%B8%EC%9A%A9%EC%82%AC",
      "https://www.machuda.kr/blog/article/63"
    ]
  },

  "exam_structure": {
    "title": "시험 구조",
    "written_exam": {
      "format": "객관식 4지선다형",
      "questions": 60,
      "duration_minutes": 60,
      "max_score": 100,
      "passing_score": 60,
      "subjects": [
        "미용이론",
        "공중보건학",
        "소독학",
        "피부학",
        "공중위생법규"
      ],
      "note": "CBT(컴퓨터 기반 시험) 방식으로 시행"
    },
    "practical_exam": {
      "format": "작업형",
      "total_duration_minutes": 145,
      "max_score": 100,
      "passing_score": 60,
      "tasks": [
        {
          "task_number": 1,
          "name": "두피 스케일링 및 샴푸",
          "duration_minutes": 25,
          "description": "두피 스케일링 기법과 샴푸 시술"
        },
        {
          "task_number": 2,
          "name": "헤어 커트",
          "duration_minutes": 30,
          "description": "블로킹 4영역 분할 후 지정된 기법으로 커트. 1영역 왼→오, 2영역 오→왼 45도 이상, 3영역 오블롱 형태, 4영역 벽돌쌓기 기법"
        },
        {
          "task_number": 3,
          "name": "헤어 드라이",
          "duration_minutes": 25,
          "description": "드라이어를 사용한 헤어 스타일링"
        },
        {
          "task_number": 4,
          "name": "퍼머넌트 와인딩",
          "duration_minutes": 30,
          "description": "9등분 블로킹 후 기본형/혼합형 중 시험위원 지정에 따라 시술. 고무밴딩은 반드시 11자형으로만 해야 함"
        },
        {
          "task_number": 5,
          "name": "헤어 염색",
          "duration_minutes": 25,
          "description": "지정된 염색 기법에 따른 시술"
        }
      ],
      "changes_2025": [
        "미완성·오작 시 실격 처리(채점 대상에서 제외)",
        "퍼머넌트 웨이브 과제 종료 후 시험위원 지시에 따라 로드 아웃 등 작업분 변형/제거 필요",
        "대동모델 네일 컬러링·디자인 등 일부 허용, 수험자 눈에 보이는 표식은 불허",
        "2025년 상시 제1회 실기시험부터 시행"
      ]
    },
    "sources": [
      "https://www.q-net.or.kr/crf005.do?id=crf00503&jmCd=7937",
      "https://updokorea.com/entry/2025%EB%85%84-%EB%AF%B8%EC%9A%A9%EC%82%AC%EC%9D%BC%EB%B0%98-%EC%8B%A4%EA%B8%B0%EC%8B%9C%ED%97%98%EB%AC%B8%EC%A0%9C-%EB%B3%80%EA%B2%BD-%EC%82%AC%ED%95%AD",
      "https://updokorea.com/entry/2025%EB%85%84-%EB%AF%B8%EC%9A%A9%EC%82%AC-%EC%8B%A4%EA%B8%B0-%ED%97%A4%EC%96%B4-%ED%8D%BC%EB%A8%B8%EB%84%8C%ED%8A%B8-%EC%9B%A8%EC%9D%B4%EB%B8%8C-%EA%B3%BC%EC%A0%9C",
      "https://namu.wiki/w/%EB%AF%B8%EC%9A%A9%EC%82%AC"
    ]
  },

