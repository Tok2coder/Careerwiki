            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "대학병원 정신건강의학과" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "체계적 수련, 다양한 검사 경험" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "TO 극소, 석사 우대" }] }] },
