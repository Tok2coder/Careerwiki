            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "★★☆" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "범위 넓지만 기초적, 학부 수준" }] }] },
