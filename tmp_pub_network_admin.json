            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "OSI 7계층, LAN/WAN 구조, 프로토콜 기초" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "약 25%" }] }] }
