            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "2~4주" }] }] },
            { "type": "tableCell", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "교육과정 중 병행 학습 권장" }] }] }
          ]
        },
        {
          "type": "tableRow",
          "content": [
